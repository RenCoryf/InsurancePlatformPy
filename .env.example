# Окружение: "production" включает проверку при старте, что секреты
# (INTERNAL_SECRET, ADMIN_PASSWORD) изменены со значений по умолчанию.
ENVIRONMENT=production

# Database
# DB_HOST=database — имя сервиса из docker-compose; для локального запуска без
# докера поменяйте на localhost. Эти же DB_USER/DB_PASSWORD/DB_NAME использует
# контейнер postgres при инициализации.
DB_HOST=database
DB_PORT=5432
DB_NAME=insurance_platform
DB_USER=postgres
DB_PASSWORD=change-me-db-password

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Chat (new in 2026-05-21 design)
INTERNAL_SECRET=change-me-to-a-long-random-string
MAX_MESSAGE_BYTES=64000
MAX_FILE_BYTES=25000000

# MinIO
# Внутри compose приложение ходит в MinIO по имени сервиса minio:9000.
# ВАЖНО: presigned-ссылки на файлы генерируются с этим же хостом. Если ссылки
# должны открываться у внешних клиентов — укажите здесь <IP-сервера>:9000
# (порт 9000 опубликован наружу в docker-compose.yml).
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=chat-files
MINIO_SECURE=false

# Admin
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Фоновые задачи APScheduler (начисление бонусов раз в час, SMS раз в минуту)
SCHEDULER_ENABLED=true

# Redis (OTP-коды, кеш настроек, лимиты SMS)
# REDIS_HOST=redis — имя сервиса из docker-compose; локально — localhost.
# Пароль обязателен: redis в compose стартует с --requirepass.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# SMSC.ru (пустые значения = dev-режим, код пишется в лог)
SMSC_LOGIN=
SMSC_PASSWORD=
SMS_LK_URL=https://smsc.ru

# Приглашения менеджеров
INVITE_LINK_BASE_URL=https://example.com
SUPPORT_INVITE_TTL_HOURS=72

# Первичный владелец (scripts/init_owner.py)
OWNER_LOGIN=owner
OWNER_PASSWORD=change-me-once
OWNER_PHONE=
